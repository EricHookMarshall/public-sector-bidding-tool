# Local config for the bidding tool API — COPY to `src/.env` and fill in.
# `.env` is git-ignored; never commit real keys (CLAUDE.md hard rule).
# The API reads these from the environment; the browser never sees them.

# --- LLM provider (Triage AI pre-fill) ---------------------------------------
# Which provider llm.py uses. Today: "anthropic". Later: "azure_openai".
LLM_PROVIDER=anthropic

# Anthropic (default provider). Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Optional model override. Default: claude-haiku-4-5 (cheapest capable model for
# this review-before-save drafting task). Bump to claude-opus-4-8 if needed.
# ANTHROPIC_MODEL=claude-haiku-4-5

# --- Azure OpenAI (planned — provider not built yet; see llm.py) -------------
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-10-21

# --- Entra ID auth (src/auth.py — Azure-migration Phase C) -------------------
# Local dev: leave LOCAL_AUTH_BYPASS=1 and the API runs unauthenticated (a
# synthetic Admin identity), exactly as the PoC did. Set it to 0 (or unset) to
# require a real Entra Bearer token on every /api/* call.
LOCAL_AUTH_BYPASS=1
# Role the bypass shim grants (default "Admin" = full local access). Set to
# "User" to run the local app as an employee and watch role-gating live —
# Admin-only routes (Settings writes) then return 403.
# LOCAL_AUTH_ROLE=Admin
# When bypass is off, these two are REQUIRED (the API fails closed without them):
#   AAD_TENANT_ID      = the Entra tenant GUID
#   AAD_API_CLIENT_ID  = the API app-registration client id (= the token audience)
# AAD_TENANT_ID=
# AAD_API_CLIENT_ID=
# Optional — group→role mapping (JSON object of Entra group object id → role).
# Two roles / two Entra security groups: "Admin" (god rights within the app) and
# "User" (employee working a bid through the stages). Map BOTH group object ids:
# AAD_GROUP_ROLE_MAP={"<admin-group-object-id>":"Admin","<user-group-object-id>":"User"}
# Role for an authenticated caller in neither mapped group. Default "User"
# (least privilege); set to "" to require membership of the User or Admin group.
# AAD_DEFAULT_ROLE=User

# --- CORS (Azure-migration Phase C/D) ---------------------------------------
# Comma-separated allowed origins. Defaults to the local Vite dev server. In
# Azure set this to the Static Web App hostname (separate origin from the API).
# CORS_ALLOWED_ORIGINS=https://<your-swa>.azurestaticapps.net
