# --- OS / editor cruft ---
.DS_Store
*.swp
.idea/
.vscode/

# --- Skills: keep as extracted folders, never commit packaged bundles ---
# The B-series skills live as folders (SKILL.md + scripts/ + references/). The
# zipped/.skill bundles are build artifacts — extract them, don't track them.
skills/**/*.zip
skills/**/*.skill

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# --- Node / web ---
node_modules/
dist/
*.log
npm-debug.log*

# --- Local data / secrets (never commit) ---
# Client-confidential bid content (financials, certs, CVs, past submissions) —
# hard rule in CLAUDE.md: this belongs in SharePoint, never committed here.
knowledge/SharePoint Folder/

# Bulk notice cache (cf_bulk.py) — ~440 daily OCDS extracts, rebuildable in ~12 min
# from the public S3 feed. Same rule as bids.db: derived data, not source.
src/.cache/

# SQLite PoC database is rebuildable from the connectors; keep it out of git.
src/bids.db
src/bids.db-wal
src/bids.db-shm

# Compliance-asset uploads (ISO certs, insurance, policies) — company-confidential;
# same hard rule as the bid library. The bytes live here locally (LocalFileStore),
# SharePoint later; never committed.
src/compliance_store/
*.sqlite
*.sqlite3
.env
.env.*
!.env.example
secrets.*
credentials.*
