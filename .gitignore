# --- OS / editor cruft ---
.DS_Store
*.swp
.idea/
.vscode/

# --- Skills: keep as extracted folders, never commit packaged bundles ---
# The B-series skills live as folders (SKILL.md + scripts/ + references/). The
# zipped/.skill bundles are build artifacts — extract them, don't track them.
skills/**/*.zip
skills/**/*.skill

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# --- Node / web ---
node_modules/
dist/
*.log
npm-debug.log*

# --- Local data / secrets (never commit) ---
# Client-confidential bid content (financials, certs, CVs, past submissions) —
# hard rule in CLAUDE.md: this belongs in SharePoint, never committed here.
knowledge/SharePoint Folder/

# SQLite PoC database is rebuildable from the connectors; keep it out of git.
src/bids.db
src/bids.db-wal
src/bids.db-shm
*.sqlite
*.sqlite3
.env
.env.*
!.env.example
secrets.*
credentials.*
