# Local SQLite database (regenerated by the connectors; not source)
bids.db
bids.db-wal
bids.db-shm

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Node / frontend (web/ also has its own .gitignore)
node_modules/
dist/

# Env / secrets — ignore real env files, but keep the committed template.
.env
.env.*
!.env.example

# OS / editor cruft
.DS_Store
*.swp
